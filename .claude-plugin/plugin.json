{
  "name": "splitwise-mcp",
  "version": "1.1.0",
  "description": "MCP server for Splitwise — natural-language expense and group management via the Splitwise API",
  "author": {
    "name": "Chris Hall",
    "email": "chris.c.hall@gmail.com"
  },
  "homepage": "https://github.com/chrischall/splitwise-mcp",
